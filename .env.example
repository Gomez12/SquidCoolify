# === Squid Proxy ===
# Comma-separated list of allowed IPs/CIDRs (leave empty to allow all RFC1918)
# Examples: 192.168.1.10,10.0.0.0/24,172.16.0.5
ALLOWED_IPS=

# External port for Squid (default: 3128)
SQUID_PORT=3128

# === SquidStats ===
SQUIDSTATS_PASSWORD=admin
SQUIDSTATS_SECRET_KEY=changeme-to-random-string

# === General ===
TZ=Europe/Amsterdam
